#!/bin/sh

source $HOME/.cache/wal/colors.sh

result_file="$HOME/.local/share/wmenu-calc/last_result"

set_result() { echo "$1" > $result_file; }

main() {
    wmenu_cmd="wmenu -M dddddd -m 333333 -N 333333 -n dddddd -S dddddd -s 333333 -b -p"

    while
        input=$( tac $result_file | ${wmenu_cmd} "bc: " "$@" )
    do
	equation=$( echo "$input" | bc -l )
	set_result "$equation"
    done
}

main "$@"
